# Copy to .env and fill in. .env is gitignored. Prefer macOS Keychain for tokens.

# --- Engine runtime (NEEDED FIRST) ---
# Separate from your Claude Code subscription. Get from console.anthropic.com.
# NOTE: .env.example is committed to git. Keep this a placeholder; put the real
# key only in .env (gitignored).
ANTHROPIC_API_KEY=

# --- Salesforce ---
# Two auth paths. SF_AUTH=cli (default) uses the Salesforce CLI: run
#   `sf org login web`  (browser login, no app to create), then SOURCE=salesforce.
# Optionally pin which org with SF_TARGET_ORG (alias or username); blank uses your
# default org.
SF_AUTH=cli
SF_TARGET_ORG=
# SF_AUTH=eca uses a dedicated External Client App (the spec path); fill these:
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com
SF_USERNAME=
# refresh token is obtained via the one-time browser auth and stored in Keychain:
#   uv run python -m engine.sf_login
SF_REDIRECT_URI=http://localhost:8765/callback
SF_API_VERSION=v60.0
# Set SOURCE=salesforce to poll real open lead tasks (default is fixtures).
SOURCE=fixtures
# MODE=fast (5-min poll, default) or MODE=slow (nightly learning). The launchd
# jobs set this; you rarely set it by hand.
MODE=fast
# Your Salesforce instance URL, used to hyperlink candidate accounts in Slack.
SF_INSTANCE_URL=https://posthog.my.salesforce.com
# This org has no Lead objects: a "lead" is a Task related to a Contact. The poll
# selects open Tasks (Who.Type='Contact') you own. SF_LEAD_TASK_FILTER optionally
# narrows that to the subset you treat as leads (a raw SOQL fragment), e.g.
#   Type = 'Lead'   or   Subject LIKE '%lead%'
SF_LEAD_TASK_FILTER=
# Optional custom field API names. Routing falls back to the Contact's LeadSource
# (Product-led -> PLG; form/mailbox -> inbound) and inbound-message presence.
# account_ref defaults to the Contact's AccountId.
SF_TRIGGER_TASK_FIELD=
SF_TRIGGER_CONTACT_FIELD=
SF_ACCOUNT_REF_CONTACT_FIELD=

# --- Gmail (Google Cloud OAuth) (NEEDED to stage drafts headless) ---
# Create an OAuth client in Google Cloud, then consent once:
#   uv run python -m engine.gmail_login
# The refresh token lands in the Keychain. GMAIL_ACCOUNT is your address.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_ACCOUNT=
GMAIL_REDIRECT_URI=http://localhost:8765/callback

# --- Rep identity (used in drafts) ---
# Your name for the email sign-off (drafts are signed with this). Defaults to Chris.
REP_SIGNATURE=
# Your booking link. The drafter uses it verbatim for any "my calendar" style CTA
# and never invents one; leave blank to omit scheduling links from drafts. setup.sh
# prompts for this. Example: https://calendly.com/you/30min
REP_CALENDAR_URL=

# --- Slack app (NEEDED for the review surface + notifications) ---
# Create a Slack app with a bot token (chat:write, conversations.replies). The bot
# DMs you, so you actually get notified. SLACK_USER_ID is your Slack user id (the
# bot's DM target).
SLACK_BOT_TOKEN=
SLACK_USER_ID=

# --- Enrichment provider (person/company) ---
# Pick a provider with a sync REST API, copy config/enrichment.example.yaml to
# config/enrichment.yaml, fill the endpoints + field maps, and set the key here.
# Until set, person/company enrichment falls back to the stub (thin dossiers).
ENRICHMENT_API_KEY=

# --- PostHog usage ---
# Usage is read from PostHog + Vitally fields denormalized on the Salesforce
# Account, so no PostHog API key is needed for the account-level signal. These are
# only for a future direct-PostHog roster pull.
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com
