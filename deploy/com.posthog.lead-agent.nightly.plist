<?xml version="1.0" encoding="UTF-8"?>
<!--
  Agent-plus-MCP nightly learning loop: once a day, off-hours, run the
  lead-agent-nightly skill as a local Claude agent using your connected MCPs.

  Install (edit the path first):
    cp deploy/com.posthog.lead-agent.nightly.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.posthog.lead-agent.nightly.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.posthog.lead-agent.nightly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/evilmac/Dev/lead-scout/scripts/run_nightly.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/evilmac/Dev/lead-scout</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>SOURCE</key><string>salesforce</string>
        <key>LEDGER_PATH</key>
        <string>/Users/evilmac/Dev/lead-scout/ledger/lead_runs.db</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <!-- nightly at 02:30 local -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>2</integer>
        <key>Minute</key><integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/evilmac/Dev/lead-scout/ledger/nightly.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/evilmac/Dev/lead-scout/ledger/nightly.err.log</string>
</dict>
</plist>
